{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workspace Assistant",
  "version": "0.1.0",
  "identifier": "com.workspace.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workspace Assistant",
        "width": 760,
        "height": 620,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": []
  }
}
