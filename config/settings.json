    "use_openai_sdk": true,
    "openai_api_key_env": "OPENAI_API_KEY",
    "api_key_env": "OLLAMA_API_KEY"
  },
  "feedback": {
    "sound_on_success": false,
    "log_commands": true
  },
  "paths": {
    "config_dir": "config",
    "presets_file": "config/presets.json",
    "apps_file": "config/apps.json"
  }
