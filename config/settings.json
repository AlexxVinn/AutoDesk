{
  "host": "127.0.0.1",
  "port": 9477,
  "voice": {
    "enabled": true,
    "always_listen": true,
    "wake_word_enabled": false,
    "wake_word": "hey desk",
    "sample_rate": 16000,
    "chunk_seconds": 2.0,
    "silence_threshold": 0.012,
