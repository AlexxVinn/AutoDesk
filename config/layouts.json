{
  "cursor_right_chrome_tl_telegram_bl": {
    "label": "Cursor right | Chrome top-left | Telegram bottom-left",
    "alias": [
      "cursor right chrome top left telegram bottom left",
      "chrome top left telegram bottom left cursor right"
    ],
    "slots": [
      { "app_id": "chrome", "zone": "top_left" },
      { "app_id": "telegram", "zone": "bottom_left" },
      { "app_id": "cursor", "zone": "right" }
    ]
  },
